{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "wp-restatify-forms/form-trigger",
	"version": "1.0.0",
	"title": "Form Trigger (Restatify)",
	"category": "widgets",
	"description": "Renders a button or link that opens a Restatify Form popup.",
	"keywords": ["form", "popup", "restatify", "contact"],
	"textdomain": "wp-restatify-forms",
	"usesContext": [],
	"attributes": {
		"formId": {
			"type": "string",
			"default": ""
		},
		"label": {
			"type": "string",
			"default": "Kontakt aufnehmen"
		},
		"style": {
			"type": "string",
			"default": "button",
			"enum": ["button", "link"]
		}
	},
	"supports": {
		"html": false,
		"color": {
			"background": false,
			"text": false
		}
	},
	"editorScript": "file:./index.js",
	"render": "file:./render.php"
}
