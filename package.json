{
  "name": "wp-restatify-forms",
  "version": "1.0.0",
  "description": "Restatify Forms – Multi-form popup builder for WordPress",
  "scripts": {
    "build": "wp-scripts build src/block/index.js --output-path=build/block && node -e \"const fs=require('fs');fs.mkdirSync('build/block',{recursive:true});fs.copyFileSync('src/block/block.json','build/block/block.json');fs.copyFileSync('src/block/render.php','build/block/render.php');\"",
    "start": "wp-scripts start src/block/index.js --output-path=build/block",
    "package": "pwsh -NoProfile -ExecutionPolicy Bypass -File ./scripts/create-release-zip.ps1"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0"
  },
  "license": "GPL-2.0-or-later"
}
